# ─── Frontend ───
# API URL used by the Expo app at build time (baked into the JS bundle).
# In production behind nginx, use /api/v1 so requests hit the nginx proxy.
# For dev (Expo Go on phone), set to your backend's full URL.
EXPO_PUBLIC_API_URL=/api/v1

# Port the frontend nginx listens on
FRONTEND_PORT=3000

# Traefik / Coolify hostname
TRAEFIK_HOST=brownies.yourdomain.com

# ─── Backend ───
# Optional: use a pre-built backend image or leave default
# BACKEND_IMAGE=ghcr.io/your-org/brownies-backend:latest

DATABASE_URL=postgresql://brownies:brownies@brownies-db:5432/brownies
DB_USER=brownies
DB_PASSWORD=brownies
DB_NAME=brownies

SECRET_KEY=replace-with-a-random-64-char-string
