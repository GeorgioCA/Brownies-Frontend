# ─── Frontend ───
# Backend API URL baked into the Expo web build.
# Set this to your backend's full URL (including /api/v1).
# Example: https://api.yourdomain.com/api/v1
EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# Port the frontend nginx listens on
FRONTEND_PORT=3000

# Traefik / Coolify hostname for this frontend
TRAEFIK_HOST=brownies.yourdomain.com
